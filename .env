# CivilDesk Frontend — Variables de entorno
# Copia este archivo como .env en civildesk-web/

# Cloudinary (para subir fotos de reportes)
# Crea una cuenta en https://cloudinary.com (gratis)
# Settings > Upload > Upload presets > Add unsigned preset
VITE_CLOUDINARY_CLOUD_NAME=tu_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=tu_upload_preset

# Si no configuras Cloudinary, las fotos se guardan como base64 localmente
# (funcionará para demo, pero no persiste entre sesiones)
